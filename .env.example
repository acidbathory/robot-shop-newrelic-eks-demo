# New Relic Demo Certification — environment template.
# Copy to .env and fill in. .env is gitignored. Values can be sourced from the
# macOS Keychain (see scripts/load-env.sh).

# --- New Relic ---
NEW_RELIC_USER_KEY=NRAK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # User API key (NerdGraph: dashboards, alerts, queries)
NEW_RELIC_INGEST_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxNRAL    # License/Ingest key (nri-bundle, OTel collector, APM agent)
NEW_RELIC_ACCOUNT_ID=8059020                            # Numeric account id (CA-IND-ABAL-Sandbox)
NEW_RELIC_OTLP_ENDPOINT=https://otlp.nr-data.net        # US datacenter (NRAL). EU would be https://otlp.eu01.nr-data.net
NEW_RELIC_API_ENDPOINT=https://api.newrelic.com/graphql # US NerdGraph

# --- Cluster / AWS ---
CLUSTER=robot-shop-eks
AWS_REGION=ap-south-1
ECR_REGISTRY=926634327293.dkr.ecr.ap-south-1.amazonaws.com

# --- Anthropic (Phase 5) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx                        # required for the Claude shop-assistant
ANTHROPIC_MODEL=claude-haiku-4-5                         # cheap default for demo volume
